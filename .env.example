# MongoDB Atlas connection string (users and reset tokens live here)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ezcar?retryWrites=true&w=majority

# Used to sign and verify JWTs (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Express port
PORT=5000

# Anthropic Claude API for /ai/chat
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
